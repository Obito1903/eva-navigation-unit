import { Theme } from "../theme.slint";
import { HudPanel } from "../components/hud_panel.slint";
import { GlowText } from "../components/glow_text.slint";
import { SettingsAndroidAutoTab } from "settings_android_auto.slint";
import { SettingsUiTab } from "settings_ui.slint";

// System / settings view with category tabs.
export component SettingsView inherits Rectangle {
    background: Theme.bg;

    // 0 = Android Auto  |  1 = UI
    in-out property <int> active-tab: 0;

    // Android Auto DPI (exposed for Rust binding)
    in-out property <int> aa-dpi: 160;
    in-out property <int> aa-min-dpi: 80;
    in-out property <int> aa-max-dpi: 640;
    callback aa-dpi-changed(int);

    // Wireless Android Auto enable/disable
    in-out property <bool> aa-wireless-enabled: true;
    callback aa-wireless-changed(bool);

    // Android Auto video resolution (720 or 1080 vertical lines)
    in-out property <int> aa-resolution: 720;
    callback aa-resolution-changed(int);

    // Android Auto video frame rate (30 or 60 fps)
    in-out property <int> aa-fps: 30;
    callback aa-fps-changed(int);

    // View transition mode: 0 = CRT | 1 = FADE | 2 = SLIDE
    in-out property <int> transition-mode: 0;
    callback transition-changed(int);

    // Color theme: 0 = NERV-HQ | 1 = MATRIX
    in-out property <int> theme-id: 0;
    callback theme-changed(int);

    // Android Auto video start/stop transition: 0 = CRT | 1 = FADE | 2 = SLIDE
    in-out property <int> aa-video-transition-mode: 1;
    callback aa-video-transition-changed(int);

    // Transition speed multipliers (1.0 = default; higher = faster).
    in-out property <float> transition-speed: 1.0;
    callback transition-speed-changed(float);
    in-out property <float> aa-video-transition-speed: 1.0;
    callback aa-video-transition-speed-changed(float);

    HudPanel {
        width: 100%;
        height: 100%;

        VerticalLayout {
            spacing: 0px;

            // ── Tab bar ───────────────────────────────────────────────
            Rectangle {
                height: 48px;
                background: transparent;

                HorizontalLayout {
                    alignment: start;
                    padding-left: 16px;
                    padding-top: 8px;
                    spacing: 4px;

                    // Tab: Android Auto
                    Rectangle {
                        width: tab-aa-text.preferred-width + 32px;
                        height: 36px;
                        background: root.active-tab == 0 ? Theme.red-dim : transparent;
                        border-width: 1px;
                        border-color: root.active-tab == 0 ? Theme.red : Theme.red-dim;

                        tab-aa-text := Text {
                            text: "ANDROID AUTO";
                            color: root.active-tab == 0 ? Theme.text : Theme.text-mute;
                            font-size: 12px;
                            font-weight: 700;
                            letter-spacing: 2px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.active-tab = 0;
                            }
                        }
                    }

                    // Tab: UI
                    Rectangle {
                        width: tab-ui-text.preferred-width + 32px;
                        height: 36px;
                        background: root.active-tab == 1 ? Theme.red-dim : transparent;
                        border-width: 1px;
                        border-color: root.active-tab == 1 ? Theme.red : Theme.red-dim;

                        tab-ui-text := Text {
                            text: "UI";
                            color: root.active-tab == 1 ? Theme.text : Theme.text-mute;
                            font-size: 12px;
                            font-weight: 700;
                            letter-spacing: 2px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.active-tab = 1;
                            }
                        }
                    }
                }
            }

            // Divider
            Rectangle {
                height: 1px;
                background: Theme.red-dim;
            }

            // ── Tab content ───────────────────────────────────────────
            Rectangle {
                vertical-stretch: 1;
                clip: true;

                if root.active-tab == 0 : SettingsAndroidAutoTab {
                    width: 100%;
                    height: 100%;
                    dpi <=> root.aa-dpi;
                    min-dpi <=> root.aa-min-dpi;
                    max-dpi <=> root.aa-max-dpi;
                    dpi-changed(v) => {
                        root.aa-dpi-changed(v);
                    }
                    wireless-enabled <=> root.aa-wireless-enabled;
                    wireless-changed(on) => {
                        root.aa-wireless-changed(on);
                    }
                    resolution <=> root.aa-resolution;
                    resolution-changed(v) => {
                        root.aa-resolution-changed(v);
                    }
                    fps <=> root.aa-fps;
                    fps-changed(v) => {
                        root.aa-fps-changed(v);
                    }
                }

                if root.active-tab == 1 : SettingsUiTab {
                    width: 100%;
                    height: 100%;
                    theme-id <=> root.theme-id;
                    theme-changed(v) => {
                        root.theme-changed(v);
                    }
                    transition-mode <=> root.transition-mode;
                    transition-changed(v) => {
                        root.transition-changed(v);
                    }
                    aa-video-transition-mode <=> root.aa-video-transition-mode;
                    aa-video-transition-changed(v) => {
                        root.aa-video-transition-changed(v);
                    }
                    transition-speed <=> root.transition-speed;
                    transition-speed-changed(v) => {
                        root.transition-speed-changed(v);
                    }
                    aa-video-transition-speed <=> root.aa-video-transition-speed;
                    aa-video-transition-speed-changed(v) => {
                        root.aa-video-transition-speed-changed(v);
                    }
                }
            }
        }
    }
}
