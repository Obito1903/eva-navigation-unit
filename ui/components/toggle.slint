import { Theme } from "../theme.slint";

// NERV-styled on/off toggle switch. Emits `toggled(bool)` when tapped.
export component Toggle inherits Rectangle {
    in-out property <bool> checked: false;
    in property <bool> enabled: true;
    callback toggled(bool);

    width: 56px;
    height: 28px;
    border-radius: self.height / 2;
    background: root.checked ? Theme.red-dim : Theme.panel-btn;
    border-width: 1px;
    border-color: root.checked ? Theme.red : Theme.red-dim;
    animate background, border-color { duration: 150ms; easing: ease-in-out; }

    knob := Rectangle {
        width: 22px;
        height: 22px;
        border-radius: self.height / 2;
        y: (parent.height - self.height) / 2;
        x: root.checked ? parent.width - self.width - 3px : 3px;
        background: root.checked ? Theme.text : Theme.text-mute;
        animate x, background { duration: 150ms; easing: ease-in-out; }
    }

    TouchArea {
        enabled: root.enabled;
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }
}
