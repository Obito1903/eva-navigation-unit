// a310 – Android Auto head unit UI (composition root).
// NERV / "Central Dogma" aesthetic. Styling lives in theme.slint; reusable
// pieces live in components/; each screen lives in views/.
//
// To add a new view:
//   1. Create ui/views/<name>.slint exporting a component.
//   2. Import it here, add a Sidebar item, and add a ViewSlot for it.

import { Theme } from "theme.slint";
import { Sidebar } from "components/sidebar.slint";
import { ViewSlot } from "components/view_slot.slint";
import { AndroidAutoView } from "views/android_auto.slint";
import { SettingsView } from "views/settings.slint";

export component AppWindow inherits Window {
    title: "a310";
    preferred-width: 1280px;
    preferred-height: 720px;
    background: Theme.bg;

    // Updated by Rust each decoded video frame
    in-out property <image> video-frame;

    // 0 = Android Auto  |  1 = Settings
    in-out property <int> active-view: 0;

    // Connected state (controls the AA overlay)
    in-out property <bool> aa-connected: false;

    // Android Auto DPI setting
    in-out property <int> aa-dpi: 160;
    callback aa-dpi-changed(int);

    // Fired by the video TouchArea: x, y in video-source pixels, action (0=down 1=move 2=up)
    callback touch-event(float, float, int);

    // Fired by sidebar nav buttons
    callback nav-to(int);

    HorizontalLayout {
        Sidebar {
            active-view: root.active-view;
            items: [
                { icon: "▶", label: "AUTO" },
                { icon: "⚙", label: "SYS" },
            ];
            nav-to(i) => {
                root.nav-to(i);
                root.active-view = i;
            }
        }

        // ── Content area ──────────────────────────────────────────────────
        Rectangle {
            horizontal-stretch: 1;
            background: Theme.bg;
            clip: true;

            // View 0 — Android Auto (slides in from the left)
            ViewSlot {
                active: root.active-view == 0;
                slide: -32px;

                AndroidAutoView {
                    width: 100%;
                    height: 100%;
                    video-frame: root.video-frame;
                    connected: root.aa-connected;
                    active: root.active-view == 0;
                    touch-event(x, y, k) => {
                        root.touch-event(x, y, k);
                    }
                }
            }

            // View 1 — System (slides in from the right)
            ViewSlot {
                active: root.active-view == 1;
                slide: 32px;

                SettingsView {
                    width: 100%;
                    height: 100%;
                    aa-dpi <=> root.aa-dpi;
                    aa-dpi-changed(v) => {
                        root.aa-dpi-changed(v);
                    }
                }
            }
        }
    }
}
