import { Theme } from "../theme.slint";
import { HudPanel } from "../components/hud_panel.slint";
import { GlowText } from "../components/glow_text.slint";
import { ViewSlot } from "../components/view_slot.slint";

// Android Auto video view with a "locked terminal" overlay shown until the
// stream connects. Video and overlay crossfade on connect/disconnect.
export component AndroidAutoView inherits Rectangle {
    in property <image> video-frame;
    in property <bool> connected;
    in property <bool> active;
    // True once the first decoded frame after connect is available, so the
    // start transition plays on real video content rather than an empty image.
    in property <bool> video-ready;
    // View transition mode for video start/stop: 0 = CRT | 1 = FADE | 2 = SLIDE
    in property <int> transition-mode: 0;
    // Speed multiplier for the start/stop transition (1.0 = default).
    in property <float> transition-speed: 1.0;
    // Configurable branding text for the "locked terminal" overlay.
    in property <string> app-name: "EVA NAVIGATION UNIT";
    in property <string> car-name-long: "EVA-02";
    in property <string> version-text: "0.1.0";
    in property <string> waiting-text: "WAITING FOR ENTRY PLUG";
    callback touch-event(float, float, int);

    // Transparent so the GL wireframe-sphere underlay shows behind the
    // "locked terminal" home screen (the window/content backgrounds gate the
    // actual fallback color).
    background: transparent;

    // "Locked terminal" overlay shown when not yet connected. Sits *behind* the
    // video so the video's start/stop transition (CRT/fade/slide) is what plays
    // on top; the overlay is simply revealed once the video collapses away.
    Rectangle {
        width: 100%;
        height: 100%;
        background: transparent;
        opacity: (root.connected && root.video-ready) ? 0.0 : 1.0;
        visible: self.opacity > 0.0;
        animate opacity { duration: Theme.fade-anim; easing: ease-in-out; }

        HudPanel {
            width: 100%;
            height: 100%;

            VerticalLayout {
                alignment: center;
                spacing: 14px;
                padding: 32px;

                Text {
                    text: root.app-name;
                    color: Theme.text-dim;
                    font-size: 13px;
                    letter-spacing: 3px;
                    horizontal-alignment: center;
                }
                GlowText {
                    text: root.car-name-long;
                    text-color: Theme.text;
                    font-size: 52px;
                    font-weight: 800;
                    letter-spacing: 6;
                    horizontal-alignment: center;
                    glow-spread: 1px;
                }

                HorizontalLayout {
                    alignment: center;
                    spacing: 10px;

                    Text {
                        text: "VERSION ";
                        color: Theme.text-dim;
                        font-size: 13px;
                        letter-spacing: 2px;
                        vertical-alignment: center;
                    }
                    Rectangle {
                        width: 88px;
                        height: 22px;
                        background: Theme.red;
                        Text {
                            text: root.version-text;
                            color: #000000;
                            font-size: 12px;
                            font-weight: 800;
                            letter-spacing: 2px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                Text {
                    text: root.waiting-text;
                    color: Theme.text-dim;
                    font-size: 12px;
                    letter-spacing: 2px;
                    horizontal-alignment: center;
                }
            }
        }
    }

    // Video frame display — transitions in once the first frame is ready,
    // using the selected start/stop transition (CRT / fade / slide). Drawn on
    // top of the overlay so its transition is fully visible.
    ViewSlot {
        active: root.connected && root.video-ready;
        slide: 32px;
        mode: root.transition-mode;
        speed: root.transition-speed;

        Image {
            width: 100%;
            height: 100%;
            source: root.video-frame;
            image-fit: fill;
        }
    }

    // Touch area forwarded to the AA protocol.
    video-touch := TouchArea {
        width: 100%;
        height: 100%;
        // Don't capture touches while this view is hidden.
        enabled: root.active;

        // Map logical TouchArea coords → video source pixel coords.
        pointer-event(e) => {
            root.touch-event(
                video-touch.mouse-x * (root.video-frame.width / video-touch.width),
                video-touch.mouse-y * (root.video-frame.height / video-touch.height),
                e.kind == PointerEventKind.down ? 0
                    : e.kind == PointerEventKind.up ? 2
                    : 1,
            );
        }
    }
}
