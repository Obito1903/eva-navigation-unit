import { Theme } from "../theme.slint";

// Shared cyan→blue gradient used by both the horizontal and vertical capsule
// bar sliders, so the two variants stay visually identical.
global CapsuleTint {
    // Linear interpolate cyan (#5cf0d8) → mid (#3aa0e6) → blue (#2030d8).
    public pure function mix(t: float) -> color {
        return t < 0.5
            ? Colors.rgb(
                Math.round(92 + (58 - 92) * (t / 0.5)),
                Math.round(240 + (160 - 240) * (t / 0.5)),
                Math.round(216 + (230 - 216) * (t / 0.5)))
            : Colors.rgb(
                Math.round(58 + (32 - 58) * ((t - 0.5) / 0.5)),
                Math.round(160 + (48 - 160) * ((t - 0.5) / 0.5)),
                Math.round(230 + (216 - 230) * ((t - 0.5) / 0.5)));
    }
}

// A single clean capsule bar (MAGI "toxicity level" style).
component CapsuleBar inherits Rectangle {
    in property <bool> filled: false;
    in property <color> tint: #5cf0d8;
    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    Rectangle {
        x: parent.width * 0.18;
        width: parent.width * 0.64;
        height: parent.height;
        border-radius: self.width / 4;
        background: filled ? tint : #14202e;
        opacity: filled ? 1.0 : 0.5;
    }
}

// Same capsule cell, rotated 90°: a horizontal bar inset vertically, used by
// the vertical slider variant below.
component CapsuleBarV inherits Rectangle {
    in property <bool> filled: false;
    in property <color> tint: #5cf0d8;
    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    Rectangle {
        y: parent.height * 0.18;
        height: parent.height * 0.64;
        width: parent.width;
        border-radius: self.height / 4;
        background: filled ? tint : #14202e;
        opacity: filled ? 1.0 : 0.5;
    }
}

// MAGI-style horizontal capsule bar meter / slider.
// A row of rounded capsules with a smooth cyan→blue gradient that fill up to
// the selected value.
export component CapsuleBarSlider inherits Rectangle {
    in-out property <float> value: 0.5;  // 0.0 – 1.0
    // Fired continuously while dragging (use for live visual feedback).
    callback value-changed(float);
    // Fired once when the drag/tap ends (use to apply the final value).
    callback value-committed(float);
    height: 56px;

    property <int> num-bars: 96;
    property <int> filled-bars: Math.round(value * num-bars);

    Rectangle {
        background: #0a1118;
        border-width: 1px;
        border-color: #1a2838;
        border-radius: 0px;

        HorizontalLayout {
            padding: 6px;
            spacing: 2px;

            for idx in root.num-bars : CapsuleBar {
                filled: idx < root.filled-bars;
                tint: CapsuleTint.mix(idx / (root.num-bars - 1));
            }
        }

        TouchArea {
            moved => {
                if (self.pressed) {
                    root.value = clamp(self.mouse-x / self.width, 0, 1);
                    root.value-changed(root.value);
                }
            }
            pointer-event(ev) => {
                // Commit the final value once the press is released, so heavy
                // consumers don't apply every intermediate drag increment.
                if (ev.kind == PointerEventKind.up) {
                    root.value = clamp(self.mouse-x / self.width, 0, 1);
                    root.value-changed(root.value);
                    root.value-committed(root.value);
                }
            }
        }
    }
}

// MAGI-style vertical capsule bar meter / slider — same look as
// `CapsuleBarSlider`, rotated 90°: bars fill from the bottom up, dragging up
// increases the value. Used for the per-band EQ faders.
export component CapsuleBarSliderVertical inherits Rectangle {
    in-out property <float> value: 0.5;  // 0.0 (bottom) – 1.0 (top)
    // Fired continuously while dragging (use for live visual feedback).
    callback value-changed(float);
    // Fired once when the drag/tap ends (use to apply the final value).
    callback value-committed(float);
    min-height: 220px;
    min-width: 28px;

    property <int> num-bars: 20;
    property <int> filled-bars: Math.round(value * num-bars);

    Rectangle {
        background: #0a1118;
        border-width: 1px;
        border-color: #1a2838;
        border-radius: 0px;

        VerticalLayout {
            padding: 6px;
            spacing: 4px;

            for idx in root.num-bars : CapsuleBarV {
                // idx counts from the top (0) down; bars fill from the bottom,
                // so invert it before comparing against filled-bars.
                filled: (root.num-bars - 1 - idx) < root.filled-bars;
                tint: CapsuleTint.mix((root.num-bars - 1 - idx) / (root.num-bars - 1));
            }
        }

        TouchArea {
            moved => {
                if (self.pressed) {
                    root.value = clamp(1.0 - self.mouse-y / self.height, 0, 1);
                    root.value-changed(root.value);
                }
            }
            pointer-event(ev) => {
                // Commit the final value once the press is released, so heavy
                // consumers don't apply every intermediate drag increment.
                if (ev.kind == PointerEventKind.up) {
                    root.value = clamp(1.0 - self.mouse-y / self.height, 0, 1);
                    root.value-changed(root.value);
                    root.value-committed(root.value);
                }
            }
        }
    }
}
