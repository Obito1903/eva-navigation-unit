// Shared NERV / "Central Dogma" palette and animation timings.
// Imported by every component/view so styling stays in one place.
export global Theme {
    out property <color> red: #e6231b;
    out property <color> red-dim: #6b1410;
    out property <color> red-mute: #7a2620;
    out property <color> bg: #000000;
    out property <color> panel: #0a0204;
    out property <color> panel-btn: #120305;

    // Bar-level capsule colors
    out property <color> bar-bright: #70b8ff;
    out property <color> bar-mid: #3a7cdc;
    out property <color> bar-dim: #1a2540;
    out property <color> bar-cap: #9aacbe;
    out property <color> bar-cap-dim: #3a4858;
    out property <color> bar-bg: #0c1220;

    // Animation timings
    out property <duration> view-anim: 250ms;
    out property <duration> fade-anim: 400ms;
}
