// a310 – Android Auto head unit UI (composition root).
// NERV / "Central Dogma" aesthetic. Styling lives in theme.slint; reusable
// pieces live in components/; each screen lives in views/.
//
// To add a new view:
//   1. Create ui/views/<name>.slint exporting a component.
//   2. Import it here, add a Sidebar item, and add a ViewSlot for it.

import { Theme } from "theme.slint";
import { Sidebar } from "components/sidebar.slint";
import { ViewSlot } from "components/view_slot.slint";
import { AndroidAutoView } from "views/android_auto.slint";
import { SettingsView } from "views/settings.slint";

// Re-export the palette global so Rust can switch themes at runtime.
export { Theme }

export component AppWindow inherits Window {
    title: "a310";
    preferred-width: 1280px;
    preferred-height: 720px;
    background: Theme.bg;

    // Active color theme: 0 = NERV-HQ | 1 = MATRIX. Drives the global palette.
    // The global `Theme.theme-id` is updated from Rust (startup + on change).
    in-out property <int> theme-id: 0;
    callback theme-changed(int);

    // Updated by Rust each decoded video frame
    in-out property <image> video-frame;

    // 0 = Android Auto  |  1 = Settings
    in-out property <int> active-view: 0;

    // Connected state (controls the AA overlay)
    in-out property <bool> aa-connected: false;

    // True once the first decoded frame after connect is available.
    in-out property <bool> aa-video-ready: false;

    // Android Auto DPI setting
    in-out property <int> aa-dpi: 160;
    in-out property <int> aa-min-dpi: 80;
    in-out property <int> aa-max-dpi: 640;
    callback aa-dpi-changed(int);

    // Wireless Android Auto enable/disable
    in-out property <bool> aa-wireless-enabled: true;
    callback aa-wireless-changed(bool);

    // Android Auto video resolution (720 or 1080 vertical lines)
    in-out property <int> aa-resolution: 720;
    callback aa-resolution-changed(int);

    // Android Auto video frame rate (30 or 60 fps)
    in-out property <int> aa-fps: 30;
    callback aa-fps-changed(int);

    // View transition mode: 0 = CRT | 1 = FADE | 2 = SLIDE
    in-out property <int> transition-mode: 0;
    callback transition-changed(int);

    // Android Auto video start/stop transition: 0 = CRT | 1 = FADE | 2 = SLIDE
    in-out property <int> aa-video-transition-mode: 1;
    callback aa-video-transition-changed(int);

    // Transition speed multipliers (1.0 = default; higher = faster).
    in-out property <float> transition-speed: 1.0;
    callback transition-speed-changed(float);
    in-out property <float> aa-video-transition-speed: 1.0;
    callback aa-video-transition-speed-changed(float);

    // Fired by the video TouchArea: x, y in video-source pixels, action (0=down 1=move 2=up)
    callback touch-event(float, float, int);

    // Fired by sidebar nav buttons
    callback nav-to(int);

    HorizontalLayout {
        Sidebar {
            active-view: root.active-view;
            items: [
                { icon: "▶", label: "AUTO" },
                { icon: "⚙", label: "SYS" },
            ];
            nav-to(i) => {
                root.nav-to(i);
                root.active-view = i;
            }
        }

        // ── Content area ──────────────────────────────────────────────────
        Rectangle {
            horizontal-stretch: 1;
            background: Theme.bg;
            clip: true;

            // View 0 — Android Auto (slides in from the left)
            ViewSlot {
                active: root.active-view == 0;
                slide: -32px;
                mode: root.transition-mode;
                speed: root.transition-speed;

                AndroidAutoView {
                    width: 100%;
                    height: 100%;
                    video-frame: root.video-frame;
                    connected: root.aa-connected;
                    video-ready: root.aa-video-ready;
                    active: root.active-view == 0;
                    transition-mode: root.aa-video-transition-mode;
                    transition-speed: root.aa-video-transition-speed;
                    touch-event(x, y, k) => {
                        root.touch-event(x, y, k);
                    }
                }
            }

            // View 1 — System (slides in from the right)
            ViewSlot {
                active: root.active-view == 1;
                slide: 32px;
                mode: root.transition-mode;
                speed: root.transition-speed;

                SettingsView {
                    width: 100%;
                    height: 100%;
                    aa-dpi <=> root.aa-dpi;
                    aa-min-dpi <=> root.aa-min-dpi;
                    aa-max-dpi <=> root.aa-max-dpi;
                    aa-dpi-changed(v) => {
                        root.aa-dpi-changed(v);
                    }
                    transition-mode <=> root.transition-mode;
                    transition-changed(v) => {
                        root.transition-changed(v);
                    }
                    theme-id <=> root.theme-id;
                    theme-changed(v) => {
                        root.theme-changed(v);
                    }
                    aa-video-transition-mode <=> root.aa-video-transition-mode;
                    aa-video-transition-changed(v) => {
                        root.aa-video-transition-changed(v);
                    }
                    transition-speed <=> root.transition-speed;
                    transition-speed-changed(v) => {
                        root.transition-speed-changed(v);
                    }
                    aa-video-transition-speed <=> root.aa-video-transition-speed;
                    aa-video-transition-speed-changed(v) => {
                        root.aa-video-transition-speed-changed(v);
                    }
                    aa-wireless-enabled <=> root.aa-wireless-enabled;
                    aa-wireless-changed(on) => {
                        root.aa-wireless-changed(on);
                    }
                    aa-resolution <=> root.aa-resolution;
                    aa-resolution-changed(v) => {
                        root.aa-resolution-changed(v);
                    }
                    aa-fps <=> root.aa-fps;
                    aa-fps-changed(v) => {
                        root.aa-fps-changed(v);
                    }
                }
            }
        }
    }
}
