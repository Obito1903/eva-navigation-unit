import { Theme } from "../theme.slint";

// Wraps a view with one of three power/switch transitions, selectable via `mode`:
//   0 = CRT   — old-TV power on/off (squeeze to scanline, collapse to dot, phosphor flash)
//   1 = FADE  — simple opacity crossfade
//   2 = SLIDE — horizontal slide + crossfade
//
// `slide` is the horizontal offset applied while inactive (SLIDE mode only).
export component ViewSlot inherits Rectangle {
    in property <bool> active;
    in property <length> slide: -32px;
    in property <int> mode: 0;   // 0 = CRT | 1 = FADE | 2 = SLIDE
    // Speed multiplier for all timings (1.0 = default; >1 faster, <1 slower).
    in property <float> speed: 1.0;

    width: 100%;
    height: 100%;
    clip: true;

    // CRT "tube" envelope — in CRT mode its width/height are driven in two
    // staggered phases so one axis collapses/expands before the other. In the
    // other modes it stays full-size and only opacity / x are animated.
    crt := Rectangle {
        width: (root.mode == 0 && !root.active) ? 2px : parent.width;
        height: (root.mode == 0 && !root.active) ? 2px : parent.height;
        x: (parent.width - self.width) / 2 + ((root.mode == 2 && !root.active) ? root.slide : 0px);
        y: (parent.height - self.height) / 2;
        clip: true;
        opacity: root.active ? 1.0 : 0.0;

        // Horizontal sweep: expands first on power-on, collapses last on power-off.
        animate width {
            duration: Theme.crt-sweep / root.speed;
            delay: root.active ? 0ms : Theme.crt-gap / root.speed;
            easing: ease-in-out;
        }
        // Vertical unfold: expands last on power-on, collapses first on power-off.
        animate height {
            duration: Theme.crt-sweep / root.speed;
            delay: root.active ? Theme.crt-gap / root.speed : 0ms;
            easing: ease-in-out;
        }
        // Horizontal slide (SLIDE mode only). In CRT mode `x` is derived from
        // the animated `width` to keep the box centered, so it must NOT have
        // its own animation — otherwise it lags behind `width` and the picture
        // appears to slide sideways during the collapse. Duration 0 makes `x`
        // track the centering math exactly; SLIDE mode uses the real easing.
        animate x {
            duration: root.mode == 2 ? Theme.view-anim / root.speed : 0ms;
            easing: ease-in-out;
        }
        // CRT: snap to full brightness the instant the tube powers on so the
        // dot→line→full geometry sweep is what reads (never a fade-in); on
        // power-off it stays lit through the collapse, then the phosphor dies.
        // FADE/SLIDE: straightforward crossfade.
        animate opacity {
            duration: root.mode == 0
                ? (root.active ? 0ms : Theme.crt-flash / root.speed)
                : (root.mode == 1 ? Theme.fade-anim / root.speed : Theme.view-anim / root.speed);
            delay: (root.mode == 0 && !root.active) ? (Theme.crt-gap + Theme.crt-sweep) / root.speed : 0ms;
            easing: ease-in-out;
        }

        @children

        // Phosphor flash (CRT mode only) — a white wash that blooms at the
        // scanline/dot pinch point as the tube powers off, then disappears
        // with the box. Kept off entirely during power-on so the bright sweep
        // reveal is what reads.
        Rectangle {
            width: 100%;
            height: 100%;
            background: white;
            opacity: (root.mode == 0 && !root.active) ? 0.85 : 0.0;
            animate opacity {
                duration: Theme.crt-flash / root.speed;
                delay: (root.mode == 0 && !root.active) ? (Theme.crt-sweep - 10ms) / root.speed : 0ms;
                easing: ease-out;
            }
        }
    }
}
