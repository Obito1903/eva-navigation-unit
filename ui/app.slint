// eva-navigation-unit – Android Auto head unit UI (composition root).
// NERV / "Central Dogma" aesthetic. Styling lives in theme.slint; reusable
// pieces live in components/; each screen lives in views/.
//
// To add a new view:
//   1. Create ui/views/<name>.slint exporting a component.
//   2. Import it here, add a Sidebar item, and add a ViewSlot for it.

import { Theme } from "theme.slint";
import { Sidebar } from "components/sidebar.slint";
import { ViewSlot } from "components/view_slot.slint";
import { AndroidAutoView } from "views/android_auto.slint";
import { SettingsView, EqBand } from "views/settings.slint";
import { QuickControlsView } from "views/quick_controls.slint";
import { VisualizerView } from "views/visualizer.slint";

// Re-export the palette global so Rust can switch themes at runtime.
export { Theme }

export component AppWindow inherits Window {
    title: "eva-navigation-unit";
    preferred-width: 1280px;
    preferred-height: 720px;
    full-screen <=> root.fullscreen;
    // Transparent when the wireframe-sphere underlay is on, or when the
    // visualizer view is active (it is the GL background), so the GL renders
    // through. When off and not on the VIZ view, fall back to the solid theme bg.
    background: (root.gfx-bg-enabled || root.active-view == 3) ? transparent : Theme.bg;

    // Enables the rotating wireframe-sphere GL underlay (see src/gfx.rs).
    in-out property <bool> gfx-bg-enabled: true;

    // Whether the window is shown in fullscreen mode.
    in-out property <bool> fullscreen: false;
    callback fullscreen-changed(bool);

    // Wi-Fi hotspot backend: 0 = NetworkManager | 1 = hostapd.
    in-out property <int> hotspot-backend: 0;
    callback hotspot-backend-changed(int);

    // 5 GHz channel for the hostapd hotspot backend (0 = automatic).
    in-out property <int> hotspot-channel: 36;
    callback hotspot-channel-changed(int);

    // Whether JamesDSP support was compiled into this build at all (set once
    // at startup from Rust via `cfg!(feature = "jamesdsp")`), independent of
    // `dsp-connected` (the live, runtime D-Bus reachability).
    in-out property <bool> dsp-available: true;
    // JamesDSP D-Bus connection status and effect toggles (updated from Rust).
    in-out property <bool> dsp-connected: false;
    in-out property <bool> dsp-bypass-enabled: false;
    callback dsp-bypass-changed(bool);
    in-out property <bool> dsp-graphiceq-enabled: false;
    callback dsp-graphiceq-changed(bool);
    in-out property <bool> dsp-convolver-enabled: false;
    callback dsp-convolver-changed(bool);
    in-out property <bool> dsp-equalizer-enabled: false;
    callback dsp-equalizer-changed(bool);
    in-out property <bool> dsp-bassboost-enabled: false;
    callback dsp-bassboost-changed(bool);
    in-out property <[EqBand]> dsp-eq-bands: [];
    callback dsp-eq-band-changed(int, float);
    callback dsp-eq-band-committed(int, float);

    // Selects the wireframe model drawn by the GL underlay:
    // 0 = sphere | 1 = cube | 2 = car.
    in-out property <int> gfx-model: 0;
    callback gfx-model-changed(int);

    // Active color theme: 0 = NERV-HQ | 1 = MATRIX. Drives the global palette.
    // The global `Theme.theme-id` is updated from Rust (startup + on change).
    in-out property <int> theme-id: 0;
    callback theme-changed(int);

    // Sidebar header/branding text (configurable). Defaults to "NERV".
    in-out property <string> car-name-short: "NERV";

    // Configurable branding text for the Android Auto "locked terminal" overlay.
    in-out property <string> app-name: "EVA-02";
    in-out property <string> car-name-long: "EVA NAVIGATION UNIT";
    in-out property <string> aa-version-text: "0.1.0";
    in-out property <string> aa-waiting-text: "WAITING FOR ENTRY PLUG";

    // Updated by Rust each decoded video frame
    in-out property <image> video-frame;

    // Actual size (logical px) of the Android Auto video viewport (the
    // content area, i.e. the window minus the sidebar). Read by Rust to
    // negotiate a video picture whose aspect ratio matches what's really
    // displayed, instead of the whole window's aspect ratio.
    out property <int> aa-viewport-width: content-area.width / 1px;
    out property <int> aa-viewport-height: content-area.height / 1px;

    // Rotating wireframe car rendered by the GL layer (src/gfx.rs) for the
    // AUTO nav button. Updated each frame while the AUTO view is active.
    in-out property <image> auto-icon;

    // Rotating wireframe gear rendered by the GL layer (src/gfx.rs) for the
    // SYS nav button. Updated each frame while the Settings view is active.
    in-out property <image> settings-icon;

    // 0 = Android Auto  |  1 = Settings
    in-out property <int> active-view: 0;

    // Connected state (controls the AA overlay)
    in-out property <bool> aa-connected: false;

    // True once the first decoded frame after connect is available.
    in-out property <bool> aa-video-ready: false;

    // Android Auto DPI setting
    in-out property <int> aa-dpi: 160;
    in-out property <int> aa-min-dpi: 80;
    in-out property <int> aa-max-dpi: 640;
    callback aa-dpi-changed(int);

    // Wireless Android Auto enable/disable
    in-out property <bool> aa-wireless-enabled: true;
    callback aa-wireless-changed(bool);

    // USB (wired) Android Auto enable/disable
    in-out property <bool> aa-usb-enabled: true;
    callback aa-usb-changed(bool);

    // Android Auto video resolution (720 or 1080 vertical lines)
    in-out property <int> aa-resolution: 720;
    callback aa-resolution-changed(int);

    // Android Auto video frame rate (30 or 60 fps)
    in-out property <int> aa-fps: 30;
    callback aa-fps-changed(int);

    // View transition mode: 0 = CRT | 1 = FADE | 2 = SLIDE
    in-out property <int> transition-mode: 0;
    callback transition-changed(int);

    // Android Auto video start/stop transition: 0 = CRT | 1 = FADE | 2 = SLIDE
    in-out property <int> aa-video-transition-mode: 1;
    callback aa-video-transition-changed(int);

    // Transition speed multipliers (1.0 = default; higher = faster).
    in-out property <float> transition-speed: 1.0;
    callback transition-speed-changed(float);
    in-out property <float> aa-video-transition-speed: 1.0;
    callback aa-video-transition-speed-changed(float);

    // Fired by the video TouchArea: x, y in video-source pixels, action (0=down 1=move 2=up)
    callback touch-event(float, float, int);

    // Quick controls: system volume + physical screen brightness (0.0–1.0).
    in-out property <float> volume-level: 0.5;
    callback volume-changed(float);
    in-out property <float> brightness-level: 0.5;
    callback brightness-changed(float);

    // Fired by sidebar nav buttons
    callback nav-to(int);

    // Visualizer renderer: 0 = BARS | 1 = ARC
    in-out property <int> viz-renderer: 0;
    callback viz-renderer-changed(int);

    // Visualizer theme: 0 = VFD | 1 = NERV | 2 = MATRIX | 3 = NEON
    in-out property <int> viz-theme: 0;
    callback viz-theme-changed(int);

    HorizontalLayout {
        Sidebar {
            active-view: root.active-view;
            auto-icon: root.auto-icon;
            settings-icon: root.settings-icon;
            car-name-short: root.car-name-short;
            items: [
                { label: "AUTO", gl-icon: true, gl-id: 0 },
                { label: "SYS", gl-icon: true, gl-id: 1 },
                { label: "CTRL", icon: "\u{2600}", gl-icon: false },
                { label: "VIZ", icon: "\u{266b}", gl-icon: false },
            ];
            nav-to(i) => {
                root.nav-to(i);
                root.active-view = i;
            }
        }

        // ── Content area ──────────────────────────────────────────────────
        content-area := Rectangle {
            horizontal-stretch: 1;
            background: transparent;
            clip: true;

            // View 0 — Android Auto (slides in from the left)
            ViewSlot {
                active: root.active-view == 0;
                slide: -32px;
                mode: root.transition-mode;
                speed: root.transition-speed;

                AndroidAutoView {
                    width: 100%;
                    height: 100%;
                    video-frame: root.video-frame;
                    connected: root.aa-connected;
                    video-ready: root.aa-video-ready;
                    active: root.active-view == 0;
                    transition-mode: root.aa-video-transition-mode;
                    transition-speed: root.aa-video-transition-speed;
                    app-name: root.app-name;
                    car-name-long: root.car-name-long;
                    version-text: root.aa-version-text;
                    waiting-text: root.aa-waiting-text;
                    touch-event(x, y, k) => {
                        root.touch-event(x, y, k);
                    }
                }
            }

            // View 1 — System (slides in from the right)
            ViewSlot {
                active: root.active-view == 1;
                slide: 32px;
                mode: root.transition-mode;
                speed: root.transition-speed;

                SettingsView {
                    width: 100%;
                    height: 100%;
                    gfx-bg-enabled: root.gfx-bg-enabled;
                    gfx-model <=> root.gfx-model;
                    gfx-model-changed(v) => {
                        root.gfx-model-changed(v);
                    }
                    aa-dpi <=> root.aa-dpi;
                    aa-min-dpi <=> root.aa-min-dpi;
                    aa-max-dpi <=> root.aa-max-dpi;
                    aa-dpi-changed(v) => {
                        root.aa-dpi-changed(v);
                    }
                    transition-mode <=> root.transition-mode;
                    transition-changed(v) => {
                        root.transition-changed(v);
                    }
                    theme-id <=> root.theme-id;
                    theme-changed(v) => {
                        root.theme-changed(v);
                    }
                    aa-video-transition-mode <=> root.aa-video-transition-mode;
                    aa-video-transition-changed(v) => {
                        root.aa-video-transition-changed(v);
                    }
                    transition-speed <=> root.transition-speed;
                    transition-speed-changed(v) => {
                        root.transition-speed-changed(v);
                    }
                    aa-video-transition-speed <=> root.aa-video-transition-speed;
                    aa-video-transition-speed-changed(v) => {
                        root.aa-video-transition-speed-changed(v);
                    }
                    aa-wireless-enabled <=> root.aa-wireless-enabled;
                    aa-wireless-changed(on) => {
                        root.aa-wireless-changed(on);
                    }
                    aa-usb-enabled <=> root.aa-usb-enabled;
                    aa-usb-changed(on) => {
                        root.aa-usb-changed(on);
                    }
                    aa-resolution <=> root.aa-resolution;
                    aa-resolution-changed(v) => {
                        root.aa-resolution-changed(v);
                    }
                    aa-fps <=> root.aa-fps;
                    aa-fps-changed(v) => {
                        root.aa-fps-changed(v);
                    }
                    fullscreen <=> root.fullscreen;
                    fullscreen-changed(on) => {
                        root.fullscreen-changed(on);
                    }
                    hotspot-backend <=> root.hotspot-backend;
                    hotspot-backend-changed(v) => {
                        root.hotspot-backend-changed(v);
                    }
                    hotspot-channel <=> root.hotspot-channel;
                    hotspot-channel-changed(v) => {
                        root.hotspot-channel-changed(v);
                    }
                    dsp-available: root.dsp-available;
                    dsp-connected: root.dsp-connected;
                    dsp-bypass-enabled <=> root.dsp-bypass-enabled;
                    dsp-bypass-changed(on) => {
                        root.dsp-bypass-changed(on);
                    }
                    dsp-graphiceq-enabled <=> root.dsp-graphiceq-enabled;
                    dsp-graphiceq-changed(on) => {
                        root.dsp-graphiceq-changed(on);
                    }
                    dsp-convolver-enabled <=> root.dsp-convolver-enabled;
                    dsp-convolver-changed(on) => {
                        root.dsp-convolver-changed(on);
                    }
                    dsp-equalizer-enabled <=> root.dsp-equalizer-enabled;
                    dsp-equalizer-changed(on) => {
                        root.dsp-equalizer-changed(on);
                    }
                    dsp-bassboost-enabled <=> root.dsp-bassboost-enabled;
                    dsp-bassboost-changed(on) => {
                        root.dsp-bassboost-changed(on);
                    }
                    dsp-eq-bands: root.dsp-eq-bands;
                    dsp-eq-band-changed(idx, v) => {
                        root.dsp-eq-band-changed(idx, v);
                    }
                    dsp-eq-band-committed(idx, v) => {
                        root.dsp-eq-band-committed(idx, v);
                    }
                }
            }

            // View 2 — Quick controls (slides in from the right)
            ViewSlot {
                active: root.active-view == 2;
                slide: 32px;
                mode: root.transition-mode;
                speed: root.transition-speed;

                QuickControlsView {
                    width: 100%;
                    height: 100%;
                    gfx-bg-enabled: root.gfx-bg-enabled;
                    volume-level <=> root.volume-level;
                    volume-changed(v) => {
                        root.volume-changed(v);
                    }
                    brightness-level <=> root.brightness-level;
                    brightness-changed(v) => {
                        root.brightness-changed(v);
                    }
                }
            }

            // View 3 — Spectrum visualizer (slides in from the right)
            ViewSlot {
                active: root.active-view == 3;
                slide: 32px;
                mode: root.transition-mode;
                speed: root.transition-speed;

                VisualizerView {
                    width: 100%;
                    height: 100%;
                    viz-renderer <=> root.viz-renderer;
                    viz-renderer-changed(v) => {
                        root.viz-renderer-changed(v);
                    }
                    viz-theme <=> root.viz-theme;
                    viz-theme-changed(v) => {
                        root.viz-theme-changed(v);
                    }
                }
            }
        }
    }
}
