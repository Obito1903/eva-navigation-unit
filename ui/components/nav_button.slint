import { Theme } from "../theme.slint";

// A single sidebar navigation button (icon + label) with active highlight.
export component NavButton inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <bool> active;
    callback clicked;

    height: 76px;
    border-radius: 2px;
    border-width: 1px;
    border-color: root.active ? Theme.red : Theme.red-dim;
    background: root.active ? Theme.red-dim.with-alpha(0.45) : Theme.panel-btn;

    TouchArea {
        clicked => {
            root.clicked();
        }
    }

    VerticalLayout {
        alignment: center;
        spacing: 4px;

        Text {
            text: root.icon;
            color: root.active ? Theme.red : Theme.red-mute;
            font-size: 22px;
            horizontal-alignment: center;
        }
        Text {
            text: root.label;
            color: root.active ? Theme.red : Theme.red-mute;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            horizontal-alignment: center;
        }
    }
}
