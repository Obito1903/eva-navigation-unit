import { ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { HudPanel } from "../components/hud_panel.slint";
import { GlowText } from "../components/glow_text.slint";
import { SettingsAndroidAutoTab } from "settings_android_auto.slint";
import { SettingsUiTab } from "settings_ui.slint";
import { SettingsWifiBtTab } from "settings_wifi_bt.slint";
import { SettingsDspTab, EqBand } from "settings_dsp.slint";

export { EqBand }

// System / settings view with category tabs.
export component SettingsView inherits Rectangle {
    // When the GL wireframe-sphere underlay is on, use a slightly opaque
    // background so the sphere shows through faintly behind the settings;
    // otherwise fall back to the solid theme background.
    in property <bool> gfx-bg-enabled: false;
    background: root.gfx-bg-enabled ? Theme.bg.with-alpha(0.45) : Theme.bg;

    // 0 = Android Auto  |  1 = UI  |  2 = WiFi/BT  |  3 = DSP/EQ
    in-out property <int> active-tab: 0;

    // Android Auto DPI (exposed for Rust binding)
    in-out property <int> aa-dpi: 160;
    in-out property <int> aa-min-dpi: 80;
    in-out property <int> aa-max-dpi: 640;
    callback aa-dpi-changed(int);

    // Wireless Android Auto enable/disable
    in-out property <bool> aa-wireless-enabled: true;
    callback aa-wireless-changed(bool);

    // USB (wired) Android Auto enable/disable
    in-out property <bool> aa-usb-enabled: true;
    callback aa-usb-changed(bool);

    // Android Auto video resolution (720 or 1080 vertical lines)
    in-out property <int> aa-resolution: 720;
    callback aa-resolution-changed(int);

    // Android Auto video frame rate (30 or 60 fps)
    in-out property <int> aa-fps: 30;
    callback aa-fps-changed(int);

    // View transition mode: 0 = CRT | 1 = FADE | 2 = SLIDE
    in-out property <int> transition-mode: 0;
    callback transition-changed(int);

    // Color theme: 0 = NERV-HQ | 1 = MATRIX
    in-out property <int> theme-id: 0;
    callback theme-changed(int);

    // GL underlay wireframe model: 0 = sphere | 1 = cube | 2 = car
    in-out property <int> gfx-model: 0;
    callback gfx-model-changed(int);

    // Android Auto video start/stop transition: 0 = CRT | 1 = FADE | 2 = SLIDE
    in-out property <int> aa-video-transition-mode: 1;
    callback aa-video-transition-changed(int);

    // Transition speed multipliers (1.0 = default; higher = faster).
    in-out property <float> transition-speed: 1.0;
    callback transition-speed-changed(float);
    in-out property <float> aa-video-transition-speed: 1.0;
    callback aa-video-transition-speed-changed(float);

    // Whether the window is shown in fullscreen mode.
    in-out property <bool> fullscreen: false;
    callback fullscreen-changed(bool);

    // Wi-Fi hotspot backend: 0 = NetworkManager | 1 = hostapd.
    in-out property <int> hotspot-backend: 0;
    callback hotspot-backend-changed(int);

    // 5 GHz channel for the hostapd hotspot backend (0 = automatic).
    in-out property <int> hotspot-channel: 36;
    callback hotspot-channel-changed(int);

    // JamesDSP D-Bus connection status and effect toggles.
    in property <bool> dsp-available: true;
    in property <bool> dsp-connected: false;
    in-out property <bool> dsp-bypass-enabled: false;
    callback dsp-bypass-changed(bool);
    in-out property <bool> dsp-graphiceq-enabled: false;
    callback dsp-graphiceq-changed(bool);
    in-out property <bool> dsp-convolver-enabled: false;
    callback dsp-convolver-changed(bool);
    in-out property <bool> dsp-equalizer-enabled: false;
    callback dsp-equalizer-changed(bool);
    in-out property <bool> dsp-bassboost-enabled: false;
    callback dsp-bassboost-changed(bool);
    in property <[EqBand]> dsp-eq-bands: [];
    callback dsp-eq-band-changed(int, float);
    callback dsp-eq-band-committed(int, float);

    HudPanel {
        width: 100%;
        height: 100%;

        VerticalLayout {
            spacing: 0px;

            // ── Tab bar ───────────────────────────────────────────────
            Rectangle {
                height: 48px;
                background: transparent;

                HorizontalLayout {
                    alignment: start;
                    padding-left: 16px;
                    padding-top: 8px;
                    spacing: 4px;

                    // Tab: Android Auto
                    Rectangle {
                        width: tab-aa-text.preferred-width + 32px;
                        height: 36px;
                        background: root.active-tab == 0 ? Theme.red-dim : transparent;
                        border-width: 1px;
                        border-color: root.active-tab == 0 ? Theme.red : Theme.red-dim;

                        tab-aa-text := Text {
                            text: "ANDROID AUTO";
                            color: root.active-tab == 0 ? Theme.text : Theme.text-mute;
                            font-size: 12px;
                            font-weight: 700;
                            letter-spacing: 2px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.active-tab = 0;
                            }
                        }
                    }

                    // Tab: UI
                    Rectangle {
                        width: tab-ui-text.preferred-width + 32px;
                        height: 36px;
                        background: root.active-tab == 1 ? Theme.red-dim : transparent;
                        border-width: 1px;
                        border-color: root.active-tab == 1 ? Theme.red : Theme.red-dim;

                        tab-ui-text := Text {
                            text: "UI";
                            color: root.active-tab == 1 ? Theme.text : Theme.text-mute;
                            font-size: 12px;
                            font-weight: 700;
                            letter-spacing: 2px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.active-tab = 1;
                            }
                        }
                    }

                    // Tab: WiFi/BT
                    Rectangle {
                        width: tab-wifibt-text.preferred-width + 32px;
                        height: 36px;
                        background: root.active-tab == 2 ? Theme.red-dim : transparent;
                        border-width: 1px;
                        border-color: root.active-tab == 2 ? Theme.red : Theme.red-dim;

                        tab-wifibt-text := Text {
                            text: "WIFI/BT";
                            color: root.active-tab == 2 ? Theme.text : Theme.text-mute;
                            font-size: 12px;
                            font-weight: 700;
                            letter-spacing: 2px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.active-tab = 2;
                            }
                        }
                    }

                    // Tab: DSP/EQ
                    Rectangle {
                        width: tab-dsp-text.preferred-width + 32px;
                        height: 36px;
                        background: root.active-tab == 3 ? Theme.red-dim : transparent;
                        border-width: 1px;
                        border-color: root.active-tab == 3 ? Theme.red : Theme.red-dim;

                        tab-dsp-text := Text {
                            text: "DSP/EQ";
                            color: root.active-tab == 3 ? Theme.text : Theme.text-mute;
                            font-size: 12px;
                            font-weight: 700;
                            letter-spacing: 2px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.active-tab = 3;
                            }
                        }
                    }
                }
            }

            // Divider
            Rectangle {
                height: 1px;
                background: Theme.red-dim;
            }

            // ── Tab content ───────────────────────────────────────────
            Rectangle {
                vertical-stretch: 1;
                clip: true;

                if root.active-tab == 0 : Flickable {
                    width: 100%;
                    height: 100%;
                    viewport-width: self.width;
                    viewport-height: max(self.height, aa-tab.preferred-height);

                    aa-tab := SettingsAndroidAutoTab {
                    width: 100%;
                    dpi <=> root.aa-dpi;
                    min-dpi <=> root.aa-min-dpi;
                    max-dpi <=> root.aa-max-dpi;
                    dpi-changed(v) => {
                        root.aa-dpi-changed(v);
                    }
                    wireless-enabled <=> root.aa-wireless-enabled;
                    wireless-changed(on) => {
                        root.aa-wireless-changed(on);
                    }
                    usb-enabled <=> root.aa-usb-enabled;
                    usb-changed(on) => {
                        root.aa-usb-changed(on);
                    }
                    resolution <=> root.aa-resolution;
                    resolution-changed(v) => {
                        root.aa-resolution-changed(v);
                    }
                    fps <=> root.aa-fps;
                    fps-changed(v) => {
                        root.aa-fps-changed(v);
                    }
                    }
                }

                if root.active-tab == 1 : Flickable {
                    width: 100%;
                    height: 100%;
                    viewport-width: self.width;
                    viewport-height: max(self.height, ui-tab.preferred-height);

                    ui-tab := SettingsUiTab {
                    width: 100%;
                    theme-id <=> root.theme-id;
                    theme-changed(v) => {
                        root.theme-changed(v);
                    }
                    gfx-model <=> root.gfx-model;
                    gfx-model-changed(v) => {
                        root.gfx-model-changed(v);
                    }
                    transition-mode <=> root.transition-mode;
                    transition-changed(v) => {
                        root.transition-changed(v);
                    }
                    aa-video-transition-mode <=> root.aa-video-transition-mode;
                    aa-video-transition-changed(v) => {
                        root.aa-video-transition-changed(v);
                    }
                    transition-speed <=> root.transition-speed;
                    transition-speed-changed(v) => {
                        root.transition-speed-changed(v);
                    }
                    aa-video-transition-speed <=> root.aa-video-transition-speed;
                    aa-video-transition-speed-changed(v) => {
                        root.aa-video-transition-speed-changed(v);
                    }
                    fullscreen <=> root.fullscreen;
                    fullscreen-changed(on) => {
                        root.fullscreen-changed(on);
                    }
                    }
                }

                if root.active-tab == 2 : Flickable {
                    width: 100%;
                    height: 100%;
                    viewport-width: self.width;
                    viewport-height: max(self.height, wifibt-tab.preferred-height);

                    wifibt-tab := SettingsWifiBtTab {
                    width: 100%;
                    hotspot-backend <=> root.hotspot-backend;
                    hotspot-backend-changed(v) => {
                        root.hotspot-backend-changed(v);
                    }
                    hotspot-channel <=> root.hotspot-channel;
                    hotspot-channel-changed(v) => {
                        root.hotspot-channel-changed(v);
                    }
                    }
                }

                if root.active-tab == 3 : ScrollView {
                    width: 100%;
                    height: 100%;
                    viewport-width: self.width;
                    viewport-height: max(self.height, dsp-tab.preferred-height);

                    dsp-tab := SettingsDspTab {
                    width: 100%;
                    dsp-available: root.dsp-available;
                    dsp-connected: root.dsp-connected;
                    bypass-enabled <=> root.dsp-bypass-enabled;
                    bypass-changed(on) => {
                        root.dsp-bypass-changed(on);
                    }
                    graphiceq-enabled <=> root.dsp-graphiceq-enabled;
                    graphiceq-changed(on) => {
                        root.dsp-graphiceq-changed(on);
                    }
                    convolver-enabled <=> root.dsp-convolver-enabled;
                    convolver-changed(on) => {
                        root.dsp-convolver-changed(on);
                    }
                    equalizer-enabled <=> root.dsp-equalizer-enabled;
                    equalizer-changed(on) => {
                        root.dsp-equalizer-changed(on);
                    }
                    bassboost-enabled <=> root.dsp-bassboost-enabled;
                    bassboost-changed(on) => {
                        root.dsp-bassboost-changed(on);
                    }
                    eq-bands: root.dsp-eq-bands;
                    eq-band-changed(idx, v) => {
                        root.dsp-eq-band-changed(idx, v);
                    }
                    eq-band-committed(idx, v) => {
                        root.dsp-eq-band-committed(idx, v);
                    }
                    }
                }
            }
        }
    }
}
