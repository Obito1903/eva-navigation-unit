import { Theme } from "../theme.slint";
import { Dropdown } from "../components/dropdown.slint";
import { CapsuleBarSlider } from "../components/capsule_bar_slider.slint";

// UI category settings tab.
export component SettingsUiTab inherits Rectangle {
    background: transparent;

    // Color theme: 0 = NERV-HQ | 1 = MATRIX
    in-out property <int> theme-id: 0;
    callback theme-changed(int);

    // GL underlay wireframe model: 0 = sphere | 1 = cube | 2 = car
    in-out property <int> gfx-model: 0;
    callback gfx-model-changed(int);

    // View transition mode: 0 = CRT | 1 = FADE | 2 = SLIDE
    in-out property <int> transition-mode: 0;
    callback transition-changed(int);

    // Android Auto video start/stop transition: 0 = CRT | 1 = FADE | 2 = SLIDE
    in-out property <int> aa-video-transition-mode: 1;
    callback aa-video-transition-changed(int);

    // Transition speed multipliers (1.0 = default; higher = faster).
    in-out property <float> transition-speed: 1.0;
    callback transition-speed-changed(float);
    in-out property <float> aa-video-transition-speed: 1.0;
    callback aa-video-transition-speed-changed(float);

    // Selectable speed range (multiplier).
    property <float> min-speed: 0.25;
    property <float> max-speed: 3.0;

    VerticalLayout {
        alignment: start;
        padding: 24px;
        spacing: 20px;

        Text {
            text: "UI";
            color: Theme.text;
            font-size: 20px;
            font-weight: 800;
            letter-spacing: 3px;
        }

        Rectangle {
            height: 1px;
            background: Theme.red-dim;
        }

        // ── Appearance ────────────────────────────────────────────────
        VerticalLayout {
            spacing: 14px;

            Text {
                text: "APPEARANCE";
                color: Theme.text-dim;
                font-size: 12px;
                font-weight: 700;
                letter-spacing: 2px;
            }

            HorizontalLayout {
                spacing: 12px;

                Text {
                    text: "COLOR THEME";
                    color: Theme.text;
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Dropdown {
                    width: 200px;
                    options: ["NERV-HQ", "MATRIX", "NEON"];
                    current-index <=> root.theme-id;
                    selected(i) => {
                        root.theme-changed(i);
                    }
                }
            }

            HorizontalLayout {
                spacing: 12px;

                Text {
                    text: "BACKGROUND MODEL";
                    color: Theme.text;
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Dropdown {
                    width: 200px;
                    options: ["SPHERE", "CUBE", "CAR", "SPEAKER"];
                    current-index <=> root.gfx-model;
                    selected(i) => {
                        root.gfx-model-changed(i);
                    }
                }
            }
        }

        // ── Transitions ───────────────────────────────────────────────
        VerticalLayout {
            spacing: 14px;

            Text {
                text: "TRANSITIONS";
                color: Theme.text-dim;
                font-size: 12px;
                font-weight: 700;
                letter-spacing: 2px;
            }

            HorizontalLayout {
                spacing: 12px;

                Text {
                    text: "VIEW TRANSITION";
                    color: Theme.text;
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Dropdown {
                    width: 200px;
                    options: ["CRT", "FADE", "SLIDE"];
                    current-index <=> root.transition-mode;
                    selected(i) => {
                        root.transition-changed(i);
                    }
                }
            }

            // View transition speed
            VerticalLayout {
                spacing: 8px;

                HorizontalLayout {
                    spacing: 12px;

                    Text {
                        text: "SPEED";
                        color: Theme.text-dim;
                        font-size: 12px;
                        font-weight: 600;
                        letter-spacing: 1px;
                        vertical-alignment: center;
                    }

                    Text {
                        text: Math.round(root.transition-speed * 100) / 100 + "×";
                        color: Theme.text;
                        font-size: 13px;
                        font-weight: 700;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        horizontal-alignment: right;
                    }
                }

                CapsuleBarSlider {
                    height: 32px;
                    value: (root.transition-speed - root.min-speed) / (root.max-speed - root.min-speed);
                    value-changed(v) => {
                        root.transition-speed = clamp(root.min-speed + v * (root.max-speed - root.min-speed), root.min-speed, root.max-speed);
                        root.transition-speed-changed(root.transition-speed);
                    }
                }
            }

            HorizontalLayout {
                spacing: 12px;

                Text {
                    text: "AA VIDEO TRANSITION";
                    color: Theme.text;
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Dropdown {
                    width: 200px;
                    options: ["CRT", "FADE", "SLIDE"];
                    current-index <=> root.aa-video-transition-mode;
                    selected(i) => {
                        root.aa-video-transition-changed(i);
                    }
                }
            }

            // AA video transition speed
            VerticalLayout {
                spacing: 8px;

                HorizontalLayout {
                    spacing: 12px;

                    Text {
                        text: "SPEED";
                        color: Theme.text-dim;
                        font-size: 12px;
                        font-weight: 600;
                        letter-spacing: 1px;
                        vertical-alignment: center;
                    }

                    Text {
                        text: Math.round(root.aa-video-transition-speed * 100) / 100 + "×";
                        color: Theme.text;
                        font-size: 13px;
                        font-weight: 700;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        horizontal-alignment: right;
                    }
                }

                CapsuleBarSlider {
                    height: 32px;
                    value: (root.aa-video-transition-speed - root.min-speed) / (root.max-speed - root.min-speed);
                    value-changed(v) => {
                        root.aa-video-transition-speed = clamp(root.min-speed + v * (root.max-speed - root.min-speed), root.min-speed, root.max-speed);
                        root.aa-video-transition-speed-changed(root.aa-video-transition-speed);
                    }
                }
            }
        }
    }
}
