# Configuration for eva-hotspot.service (the privileged Android Auto Wi-Fi AP).
#
# Installed at /etc/eva-hotspot/hotspot.env and read by /usr/local/sbin/eva-hotspot.
# Edit as root, then `sudo systemctl restart eva-hotspot.service` to apply.
#
# This file replaces the per-run hotspot parameters that used to be passed from
# eva-ui. The unprivileged app only triggers start/stop now, so the SSID, PSK
# and channel live here where the privileged service can read them.

# Wi-Fi interface to host the AP on. Leave empty to auto-detect the first
# wireless interface (recommended for single-radio head units).
EVA_HOTSPOT_IFACE=

# Access point credentials. Must match the values eva-ui advertises to the
# phone over Bluetooth (currently the "Hotspot" / "qwertyuiop" defaults).
EVA_HOTSPOT_SSID=Hotspot
EVA_HOTSPOT_PSK=qwertyuiop

# Wi-Fi channel. Android Auto wireless requires a 5 GHz AP, so use a non-DFS
# 5 GHz channel (36/40/44/48). 0 means "pick 36".
EVA_HOTSPOT_CHANNEL=36

# Regulatory country code (e.g. FR, US, DE). Leave empty to auto-detect from
# `iw reg get`. A correct country code is required for 5 GHz/DFS operation.
EVA_HOTSPOT_COUNTRY=

# Gateway address / DHCP pool handed to the phone. Must match the address
# eva-ui advertises over Bluetooth (10.42.0.1).
EVA_HOTSPOT_GATEWAY_CIDR=10.42.0.1/24
EVA_HOTSPOT_DHCP_RANGE=10.42.0.10,10.42.0.100,255.255.255.0,12h
EVA_HOTSPOT_GATEWAY_IP=10.42.0.1
