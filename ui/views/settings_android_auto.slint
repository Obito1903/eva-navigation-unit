import { Theme } from "../theme.slint";
import { Toggle } from "../components/toggle.slint";
import { Dropdown } from "../components/dropdown.slint";
import { CapsuleBarSlider } from "../components/capsule_bar_slider.slint";

// Android Auto category settings tab.
export component SettingsAndroidAutoTab inherits Rectangle {
    background: transparent;

    // DPI value exposed to parent; bounds are configurable, default 160
    in-out property <int> dpi: 160;
    // Selectable DPI bounds (configurable via Rust); defaults match prior 80–640.
    in-out property <int> min-dpi: 80;
    in-out property <int> max-dpi: 640;
    callback dpi-changed(int);

    // Wireless Android Auto enable/disable.
    in-out property <bool> wireless-enabled: true;
    callback wireless-changed(bool);

    // Android Auto video resolution (480, 720 or 1080 vertical lines).
    in-out property <int> resolution: 720;
    callback resolution-changed(int);

    VerticalLayout {
        alignment: start;
        padding: 24px;
        spacing: 20px;

        Text {
            text: "ANDROID AUTO";
            color: Theme.text;
            font-size: 20px;
            font-weight: 800;
            letter-spacing: 3px;
        }

        Rectangle {
            height: 1px;
            background: Theme.red-dim;
        }

        // ── Display ───────────────────────────────────────────────────
        VerticalLayout {
            spacing: 14px;

            Text {
                text: "DISPLAY";
                color: Theme.text-dim;
                font-size: 12px;
                font-weight: 700;
                letter-spacing: 2px;
            }

            // DPI control
            VerticalLayout {
                spacing: 8px;

                HorizontalLayout {
                    spacing: 12px;

                    Text {
                        text: "DPI";
                        color: Theme.text;
                        font-size: 14px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }

                    Text {
                        text: root.dpi;
                        color: Theme.text;
                        font-size: 14px;
                        font-weight: 700;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        horizontal-alignment: right;
                    }
                }

                dpi-slider := CapsuleBarSlider {
                    value: (root.dpi - root.min-dpi) / (root.max-dpi - root.min-dpi);
                    value-changed(v) => {
                        root.dpi = clamp(Math.round(root.min-dpi + v * (root.max-dpi - root.min-dpi)), root.min-dpi, root.max-dpi);
                        root.dpi-changed(root.dpi);
                    }
                }

                // Min/Max labels
                HorizontalLayout {
                    Text {
                        text: root.min-dpi;
                        color: Theme.text-mute;
                        font-size: 11px;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Text {
                        text: root.max-dpi;
                        color: Theme.text-mute;
                        font-size: 11px;
                    }
                }
            }

            // Resolution control
            HorizontalLayout {
                spacing: 12px;

                Text {
                    text: "RESOLUTION";
                    color: Theme.text;
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Dropdown {
                    width: 200px;
                    options: ["480p", "720p", "1080p"];
                    current-index: root.resolution >= 1080 ? 2 : (root.resolution >= 720 ? 1 : 0);
                    selected(i) => {
                        root.resolution = i == 2 ? 1080 : (i == 1 ? 720 : 480);
                        root.resolution-changed(root.resolution);
                    }
                }
            }
        }

        // ── Connectivity ──────────────────────────────────────────
        VerticalLayout {
            spacing: 14px;

            Text {
                text: "CONNECTIVITY";
                color: Theme.text-dim;
                font-size: 12px;
                font-weight: 700;
                letter-spacing: 2px;
            }

            HorizontalLayout {
                spacing: 12px;

                Text {
                    text: "WIRELESS ANDROID AUTO";
                    color: Theme.text;
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Toggle {
                    checked <=> root.wireless-enabled;
                    toggled(on) => {
                        root.wireless-changed(on);
                    }
                }
            }
        }
    }
}
