import { Theme } from "../theme.slint";
import { HudPanel } from "../components/hud_panel.slint";
import { GlowText } from "../components/glow_text.slint";
import { ViewSlot } from "../components/view_slot.slint";

// Android Auto video view with a "locked terminal" overlay shown until the
// stream connects. Video and overlay crossfade on connect/disconnect.
export component AndroidAutoView inherits Rectangle {
    in property <image> video-frame;
    in property <bool> connected;
    in property <bool> active;
    // View transition mode for video start/stop: 0 = CRT | 1 = FADE | 2 = SLIDE
    in property <int> transition-mode: 0;
    callback touch-event(float, float, int);

    // Video frame display — transitions in once Android Auto connects, using
    // the selected start/stop transition (CRT / fade / slide).
    ViewSlot {
        active: root.connected;
        slide: 32px;
        mode: root.transition-mode;

        Image {
            width: 100%;
            height: 100%;
            source: root.video-frame;
            image-fit: fill;
        }
    }

    // "Locked terminal" overlay shown when not yet connected; crossfades out.
    Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.bg;
        opacity: root.connected ? 0.0 : 1.0;
        visible: self.opacity > 0.0;
        animate opacity { duration: Theme.fade-anim; easing: ease-in-out; }

        HudPanel {
            width: 100%;
            height: 100%;

            VerticalLayout {
                alignment: center;
                spacing: 14px;
                padding: 32px;

                Text {
                    text: "SECURITY · PERSONAL CODE";
                    color: Theme.text-dim;
                    font-size: 13px;
                    letter-spacing: 3px;
                    horizontal-alignment: center;
                }
                GlowText {
                    text: "CENTRAL DOGMA";
                    text-color: Theme.text;
                    font-size: 52px;
                    font-weight: 800;
                    letter-spacing: 6;
                    horizontal-alignment: center;
                    glow-spread: 1px;
                }

                HorizontalLayout {
                    alignment: center;
                    spacing: 10px;

                    Text {
                        text: "FINAL GATE";
                        color: Theme.text-dim;
                        font-size: 13px;
                        letter-spacing: 2px;
                        vertical-alignment: center;
                    }
                    Rectangle {
                        width: 88px;
                        height: 22px;
                        background: Theme.red;
                        Text {
                            text: "LOCKED";
                            color: #000000;
                            font-size: 12px;
                            font-weight: 800;
                            letter-spacing: 2px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                Text {
                    text: "WAITING FOR ANDROID AUTO · INSERT CARD FULLY";
                    color: Theme.text-dim;
                    font-size: 12px;
                    letter-spacing: 2px;
                    horizontal-alignment: center;
                }
            }
        }
    }

    // Touch area forwarded to the AA protocol.
    video-touch := TouchArea {
        width: 100%;
        height: 100%;
        // Don't capture touches while this view is hidden.
        enabled: root.active;

        // Map logical TouchArea coords → video source pixel coords.
        pointer-event(e) => {
            root.touch-event(
                video-touch.mouse-x * (root.video-frame.width / video-touch.width),
                video-touch.mouse-y * (root.video-frame.height / video-touch.height),
                e.kind == PointerEventKind.down ? 0
                    : e.kind == PointerEventKind.up ? 2
                    : 1,
            );
        }
    }
}
