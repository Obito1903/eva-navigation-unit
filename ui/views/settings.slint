import { Theme } from "../theme.slint";
import { HudPanel } from "../components/hud_panel.slint";
import { SettingsAndroidAutoTab } from "settings_android_auto.slint";

// System / settings view with category tabs.
export component SettingsView inherits Rectangle {
    background: Theme.bg;

    // 0 = Android Auto
    in-out property <int> active-tab: 0;

    // Android Auto DPI (exposed for Rust binding)
    in-out property <int> aa-dpi: 160;
    callback aa-dpi-changed(int);

    HudPanel {
        width: 100%;
        height: 100%;

        VerticalLayout {
            spacing: 0px;

            // ── Tab bar ───────────────────────────────────────────────
            Rectangle {
                height: 48px;
                background: transparent;

                HorizontalLayout {
                    alignment: start;
                    padding-left: 16px;
                    padding-top: 8px;
                    spacing: 4px;

                    // Tab: Android Auto
                    Rectangle {
                        width: tab-aa-text.preferred-width + 32px;
                        height: 36px;
                        background: root.active-tab == 0 ? Theme.red-dim : transparent;
                        border-width: 1px;
                        border-color: root.active-tab == 0 ? Theme.red : Theme.red-dim;

                        tab-aa-text := Text {
                            text: "ANDROID AUTO";
                            color: root.active-tab == 0 ? Theme.red : Theme.red-mute;
                            font-size: 12px;
                            font-weight: 700;
                            letter-spacing: 2px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.active-tab = 0;
                            }
                        }
                    }
                }
            }

            // Divider
            Rectangle {
                height: 1px;
                background: Theme.red-dim;
            }

            // ── Tab content ───────────────────────────────────────────
            Rectangle {
                vertical-stretch: 1;
                clip: true;

                if root.active-tab == 0 : SettingsAndroidAutoTab {
                    width: 100%;
                    height: 100%;
                    dpi <=> root.aa-dpi;
                    dpi-changed(v) => {
                        root.aa-dpi-changed(v);
                    }
                }
            }
        }
    }
}
